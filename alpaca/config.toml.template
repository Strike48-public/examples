# ─── Specifying a CUSTOM endpoint ───────────────────────────────────────────
# Point a provider's traffic at your own host with `base_url`.

# (a) Self-hosted OpenAI-compatible server (vLLM, LM Studio, LiteLLM, an
#     internal gateway, …). direct_passthrough forwards the request body as-is.
# [models."openai/my-llama-3-8b"]
# name = "Llama 3 8B (self-hosted)"
# provider = "openai"
# base_url = "http://my-inference-host:8000/v1"
# direct_passthrough = true
# upstream_model = "meta-llama/Meta-Llama-3-8B-Instruct"
# supports_tools = false
# context_limit = 8192
# output_limit = 4096
# enabled = true

# (b) Ollama on the host (base_url honored directly; host.docker.internal
#     reaches your machine from inside compose).
# [models."ollama/llama3.2"]
# name = "Llama 3.2 (local Ollama)"
# provider = "ollama"
# base_url = "http://host.docker.internal:11434"
# supports_tools = true
# context_limit = 131072
# output_limit = 4096
# enabled = true
