# Local secrets / config — generated by ./setup.sh, never committed.
.env

# TLS material (private keys) — generated.
caddy/tls/
keycloak/tls/
certs/

# Keycloak realm export — derived from the internal source (may carry secrets).
keycloak/realms/*.json

# Studio release runtime.exs — extracted from the image at setup time.
studio-overrides/runtime.exs

# Alpaca config — rendered from config.toml.template by setup.sh.
alpaca/config.toml

# Misc
*.log
erl_crash.dump

# Playwright E2E — installed deps + run artifacts (specs/config ARE committed).
tests/node_modules/
tests/test-results/
tests/playwright-report/
