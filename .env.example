# Copy to .env and fill in the blanks (or run ./setup.sh, which generates the
# secrets + local TLS/realm/runtime files for you). .env is gitignored.

# ── Image versions ───────────────────────────────────────────────────────
POSTGRES_IMAGE=pgvector/pgvector:pg16
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.5.3
RUSTFS_IMAGE=rustfs/rustfs:1.0.0-beta.8
VM_IMAGE=victoriametrics/victoria-metrics:latest
VL_IMAGE=victoriametrics/victoria-logs:latest
VT_IMAGE=victoriametrics/victoria-traces:latest
OTELCOL_IMAGE=otel/opentelemetry-collector-contrib:latest
CADDY_IMAGE=caddy:2
BUCKET_INIT_IMAGE=alpine:3

# Matrix app images — private registry (see README for the docker login step).
STUDIO_IMAGE=zot.delivery.strike48.io/strike48/matrix:2026-07-14-af553c4
ALPACA_IMAGE=zot.delivery.strike48.io/strike48/alpaca:2026-06-24-1ac5783
CONSTRUCT_IMAGE=zot.delivery.strike48.io/strike48/construct:2026-07-10-main-462664b

# ── Networking ───────────────────────────────────────────────────────────
DOMAIN=strike48.local
CADDY_HTTP_PORT=8888

# ── Credentials (example values — change before any real use) ────────────
POSTGRES_PASSWORD=postgres
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Generated secrets — leave blank and let ./setup.sh fill them, or:
#   openssl rand -base64 48   (SECRET_KEY_BASE)
#   openssl rand -base64 32   (MATRIX_ORG_AUDIT_HMAC_KEY)
SECRET_KEY_BASE=
MATRIX_ORG_AUDIT_HMAC_KEY=

# ── LLM endpoint (OpenAI-compatible) — REQUIRED, fill these in ───────────
# Studio talks to Alpaca (an LLM gateway); Alpaca forwards to the ONE
# OpenAI-compatible endpoint you define here. Point it at anything that speaks
# the OpenAI /v1 API — vLLM, SGLang, MLX, LM Studio, LiteLLM, Ollama's /v1, or
# OpenAI itself. setup.sh renders these into alpaca/config.toml.
#
#   Working example (an MLX server on a lab host):
#     LLM_BASE_URL=http://10.10.0.21:8000/v1
#     LLM_API_KEY=your-bearer-key
#     LLM_CHAT_MODEL=Qwen3.6-35B-A3B-Claude-4.7-Opus-Reasoning-Distilled
#     LLM_EMBED_MODEL=qwen3-embedding-0.6b
#     LLM_CONTEXT_LIMIT=262144
#
#   OpenAI cloud:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_API_KEY=sk-...
#     LLM_CHAT_MODEL=gpt-4o-mini
#     LLM_EMBED_MODEL=text-embedding-3-small
#     LLM_CONTEXT_LIMIT=128000
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_API_KEY=
LLM_CHAT_MODEL=your-chat-model-id
LLM_EMBED_MODEL=your-embedding-model-id
# Must match the chat model's REAL context window (the server's max_model_len).
# Studio derives max_completion_tokens ≈ LLM_CONTEXT_LIMIT/4, so a value larger
# than the server actually serves makes requests fail with an upstream 400.
LLM_CONTEXT_LIMIT=32768

# Extra providers — only needed if you enable their (commented) model blocks in
# alpaca/config.toml. Leave blank otherwise.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Feature flags ────────────────────────────────────────────────────────
# All flags enabled on boot EXCEPT these (comma-separated; each entry is a SQL
# LIKE pattern, so exact names or prefixes like policy_control_% both work).
DISABLED_FLAGS=plg_mode,sentry_unmask_data,devo_assistant_enabled,policy_control_%
